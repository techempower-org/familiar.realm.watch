{
  "name": "realm-sigil",
  "version": "1.1.0",
  "description": "Deterministic magical version name generation for JP's projects",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./handler": {
      "types": "./handler.d.ts",
      "default": "./handler.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "handler.js",
    "handler.d.ts",
    "realms.js"
  ],
  "license": "GPL-3.0-only"
}
