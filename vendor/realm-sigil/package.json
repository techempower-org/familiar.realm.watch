{
  "name": "sigil.realm.watch",
  "version": "1.2.0",
  "description": "Deterministic magical version name generation for JP's projects",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./handler": {
      "types": "./handler.d.ts",
      "default": "./handler.js"
    },
    "./react": {
      "types": "./Sigil.tsx",
      "default": "./Sigil.tsx"
    },
    "./react/style.css": "./Sigil.module.css",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "handler.js",
    "handler.d.ts",
    "realms.js",
    "Sigil.tsx",
    "Sigil.module.css"
  ],
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "license": "GPL-3.0-only"
}
